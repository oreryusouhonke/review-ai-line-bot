PORT=3000
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# ローカル検証用。本番（NODE_ENV=production）では false を指定しても署名検証は無効化されません。
LINE_VERIFY_SIGNATURE=true
GEMINI_API_KEY=
GOOGLE_PLACES_API_KEY=
# 例: おかしのたいよう（複数指定はカンマ区切り。未設定時は非表示なし）
RECRUIT_HIDDEN_KEYWORDS=
GEMINI_MODEL=gemini-flash-lite-latest
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional LINE Harness OSS forwarding.
# LINE_HARNESS_WEBHOOK_URL is preferred. If omitted, LINE_HARNESS_BASE_URL + /webhook is used.
LINE_HARNESS_WEBHOOK_URL=
LINE_HARNESS_BASE_URL=
LINE_HARNESS_API_KEY=
LINE_HARNESS_FRIEND_LOOKUP_LIMIT=1000
LINE_HARNESS_ACCOUNT_ID=
LINE_HARNESS_WEBHOOK_SECRET=

# Stripe billing.
PUBLIC_BASE_URL=https://review-ai-line-bot.onrender.com
# 0 means free unlimited. Keep this at 0 while Review Shokunin is a free tool.
FREE_MONTHLY_QUOTA=0
PAID_MONTHLY_QUOTA=30
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://review-ai-line-bot.onrender.com/billing/success
STRIPE_CANCEL_URL=https://review-ai-line-bot.onrender.com/billing/cancel
STRIPE_ALLOW_PROMOTION_CODES=false
